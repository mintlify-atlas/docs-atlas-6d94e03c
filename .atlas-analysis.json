  "keyFeatures": [
    "Student enrollment and management with class plans",
    "Instructor scheduling with color-coded calendar system",
    "Horse management (school-owned and private)",
    "Class scheduling with multiple views (day, week, month)",
    "Trial class system for prospective students",
    "Real-time validation and conflict detection",
    "Comprehensive reporting and analytics",
    "Financial tracking and board fee management",
    "Excel export for schedules and reports",
    "WhatsApp integration for communication",
    "Attendance tracking with multiple states",
    "Bulk operations (copy classes, cancel days)"
  ],
  "publicApiSurface": [
    "Student registration (DNI, personal data, class plans, horse assignments)",
    "Instructor registration (personal data, color assignment, specialties)",
    "Horse registration (name, type: ESCUELA/PRIVADO, availability)",
    "Class creation (date, time, duration, participants, specialty, state)",
    "Trial class management (new person vs existing inactive student)",
    "Calendar views (month, week, day with Excel-style grid)",
    "Reports (students, instructors, horses, classes, financial)",
    "Financial tracking (income, expenses, board fees)",
    "Class states (PROGRAMADA, INICIADA, COMPLETADA, CANCELADA, ACA, ASA)",
    "Specialties (EQUITACION, ADIESTRAMIENTO, EQUINOTERAPIA, MONTA)",
    "Board types (SIN_CABALLO, RESERVA_ESCUELA, CABALLO_PROPIO)",
    "Excel export (daily schedules with color coding and legends)"
  ]
